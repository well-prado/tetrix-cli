# =============================================================================
# Tetrix CE {{.TetrixVersion}} — Generated by tetrix CLI {{.CLIVersion}}
# DO NOT EDIT — managed by `tetrix config`
# =============================================================================

services:
  # ===========================================================================
  # Infrastructure Services
  # ===========================================================================

  postgres:
    image: ankane/pgvector:latest
    container_name: tetrix-postgres
    environment:
      POSTGRES_DB: tetrix
      POSTGRES_USER: tetrix
      POSTGRES_PASSWORD: "{{.PostgresPassword}}"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - {{.TetrixHome}}/init-pgvector.sql:/docker-entrypoint-initdb.d/init.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U tetrix"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    networks:
      - tetrix-network

  neo4j:
    image: neo4j:5.15.0
    container_name: tetrix-neo4j
    hostname: neo4j
    environment:
      NEO4J_AUTH: none
      NEO4J_dbms_security_auth__enabled: "false"
      NEO4J_PLUGINS: '["apoc"]'
      NEO4J_dbms_security_procedures_unrestricted: apoc.*
      NEO4J_server_memory_heap_initial__size: 512m
      NEO4J_server_memory_heap_max__size: 2G
      NEO4J_server_memory_pagecache_size: 512m
    command: ["bash", "-c", "rm -f /var/lib/neo4j/run/neo4j.pid && neo4j console"]
    volumes:
      - neo4j-data:/data
      - neo4j-logs:/logs
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:7474 || exit 1"]
      interval: 10s
      timeout: 10s
      retries: 10
      start_period: 40s
    restart: unless-stopped
    networks:
      - tetrix-network

  redis:
    image: redis:7-alpine
    container_name: tetrix-redis
    command: redis-server --appendonly yes
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    restart: unless-stopped
    networks:
      - tetrix-network

  meilisearch:
    image: getmeili/meilisearch:v1.5
    container_name: tetrix-meilisearch
    environment:
      MEILI_ENV: production
      MEILI_MASTER_KEY: "{{.MeilisearchKey}}"
      MEILI_NO_ANALYTICS: "true"
    volumes:
      - meilisearch-data:/meili_data
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:7700/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    restart: unless-stopped
    networks:
      - tetrix-network

  minio:
    image: minio/minio:latest
    container_name: tetrix-minio
    ports:
      - "{{.MinioAPIPort}}:9000"
      - "{{.MinioConsolePort}}:9001"
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: "{{.MinioSecretKey}}"
    command: server /data --console-address ":9001"
    volumes:
      - minio-data:/data
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    networks:
      - tetrix-network

  minio-init:
    image: minio/mc:latest
    container_name: tetrix-minio-init
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set myminio http://minio:9000 minioadmin '{{.MinioSecretKey}}';
      mc mb myminio/tetrix-uploads --ignore-existing;
      mc anonymous set download myminio/tetrix-uploads;
      echo 'MinIO bucket tetrix-uploads created';
      "
    networks:
      - tetrix-network

  vault:
    image: hashicorp/vault:1.15
    container_name: tetrix-vault
    ports:
      - "{{.VaultPort}}:8200"
    environment:
      VAULT_DEV_ROOT_TOKEN_ID: "{{.VaultToken}}"
      VAULT_DEV_LISTEN_ADDRESS: 0.0.0.0:8200
      VAULT_API_ADDR: http://0.0.0.0:8200
      VAULT_DISABLE_MLOCK: "true"
    cap_add:
      - IPC_LOCK
    command: vault server -dev -dev-root-token-id={{.VaultToken}} -dev-listen-address=0.0.0.0:8200
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:8200/v1/sys/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    restart: unless-stopped
    networks:
      - tetrix-network

  mongodb:
    image: mongo:7
    container_name: tetrix-mongodb
    environment:
      MONGO_INITDB_DATABASE: tetrix
    volumes:
      - mongodb-data:/data/db
    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped
    networks:
      - tetrix-network

  # ===========================================================================
  # Application Services (Pre-built DockerHub images)
  # ===========================================================================

  api:
    image: {{.DockerHubOrg}}/tetrix-api:{{.TetrixVersion}}
    container_name: tetrix-api
    ports:
      - "{{.APIPort}}:4000"
    depends_on:
      postgres:
        condition: service_healthy
      neo4j:
        condition: service_healthy
      redis:
        condition: service_healthy
      meilisearch:
        condition: service_healthy
      openai-proxy:
        condition: service_healthy
      credential-service:
        condition: service_healthy
    environment:
      DATABASE_URL: "postgresql://tetrix:{{.PostgresPassword}}@postgres:5432/tetrix"
      POSTGRES_URL: "postgresql://tetrix:{{.PostgresPassword}}@postgres:5432/tetrix"
      NEO4J_URI: bolt://neo4j:7687
      NEO4J_USER: neo4j
      NEO4J_PASSWORD: not_used_auth_disabled
      REDIS_URL: redis://redis:6379
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      MEILISEARCH_URL: http://meilisearch:7700
      MEILISEARCH_KEY: "{{.MeilisearchKey}}"
      AUTH_SECRET: "{{.AuthSecret}}"
      WEB_URL: "{{.AppURL}}"
      API_URL: http://api:4000
      GITHUB_CLIENT_ID: "{{.GitHubClientID}}"
      GITHUB_CLIENT_SECRET: "{{.GitHubClientSecret}}"
      GOOGLE_CLIENT_ID: "{{.GoogleClientID}}"
      GOOGLE_CLIENT_SECRET: "{{.GoogleClientSecret}}"
      GOOGLE_OAUTH_ALLOWED_DOMAIN: "{{.GoogleOAuthDomain}}"
      GITLAB_CLIENT_ID: "{{.GitLabClientID}}"
      GITLAB_CLIENT_SECRET: "{{.GitLabClientSecret}}"
      GITLAB_BASE_URL: "{{.GitLabBaseURL}}"
      LLM_PROVIDER: openai
      OPENAI_API_BASE_URL: http://openai-proxy:8085/v1
      OPENAI_API_KEY: proxy-internal-key
      ANTHROPIC_API_KEY: "{{.AnthropicAPIKey}}"
      GOOGLE_API_KEY: "{{.GoogleAPIKey}}"
      EMBEDDING_PROVIDER: openai
      VOYAGE_API_KEY: "{{.VoyageAPIKey}}"
      VECTOR_STORE: pgvector
      POSTGRES_VECTOR_DIMENSION: "1024"
      CREDENTIAL_SERVICE_URL: http://credential-service:3001
      REPO_STORAGE_PATH: /app/repos
      STORAGE_BACKEND: minio
      MINIO_ENDPOINT: minio
      MINIO_PORT: "9000"
      MINIO_USE_SSL: "false"
      MINIO_ACCESS_KEY: minioadmin
      MINIO_SECRET_KEY: "{{.MinioSecretKey}}"
      MINIO_BUCKET_UPLOADS: tetrix-uploads
      MINIO_REGION: us-east-1
      NODE_ENV: production
      SERVICE_NAME: api
      PORT: "4000"
      HOST: 0.0.0.0
    volumes:
      - repo-storage:/app/repos
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    restart: unless-stopped
    networks:
      - tetrix-network

  web:
    image: {{.DockerHubOrg}}/tetrix-web:{{.TetrixVersion}}
    container_name: tetrix-web
    ports:
      - "{{.WebPort}}:80"
    depends_on:
      api:
        condition: service_healthy
    environment:
      API_URL: http://api:4000
      PORT: "80"
      NODE_ENV: production
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://127.0.0.1:80/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 30s
      timeout: 3s
      retries: 3
      start_period: 15s
    restart: unless-stopped
    networks:
      - tetrix-network

  worker:
    image: {{.DockerHubOrg}}/tetrix-worker:{{.TetrixVersion}}
    container_name: tetrix-worker
    depends_on:
      postgres:
        condition: service_healthy
      neo4j:
        condition: service_healthy
      redis:
        condition: service_healthy
      meilisearch:
        condition: service_healthy
      minio:
        condition: service_healthy
      openai-proxy:
        condition: service_healthy
    environment:
      DATABASE_URL: "postgresql://tetrix:{{.PostgresPassword}}@postgres:5432/tetrix"
      POSTGRES_URL: "postgresql://tetrix:{{.PostgresPassword}}@postgres:5432/tetrix"
      NEO4J_URI: bolt://neo4j:7687
      NEO4J_USER: neo4j
      NEO4J_PASSWORD: not_used_auth_disabled
      REDIS_URL: redis://redis:6379
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      MEILISEARCH_URL: http://meilisearch:7700
      MEILISEARCH_KEY: "{{.MeilisearchKey}}"
      LLM_PROVIDER: openai
      OPENAI_API_BASE_URL: http://openai-proxy:8085/v1
      OPENAI_API_KEY: proxy-internal-key
      ANTHROPIC_API_KEY: "{{.AnthropicAPIKey}}"
      GOOGLE_API_KEY: "{{.GoogleAPIKey}}"
      EMBEDDING_PROVIDER: openai
      VOYAGE_API_KEY: "{{.VoyageAPIKey}}"
      VECTOR_STORE: pgvector
      POSTGRES_VECTOR_DIMENSION: "1024"
      CREDENTIAL_SERVICE_URL: http://credential-service:3001
      WORKER_CONCURRENCY: "{{.WorkerConcurrency}}"
      JOB_MAX_RETRIES: "3"
      JOB_BACKOFF_DELAY: "5000"
      REPO_STORAGE_PATH: /app/repos
      STORAGE_BACKEND: minio
      MINIO_ENDPOINT: minio
      MINIO_PORT: "9000"
      MINIO_USE_SSL: "false"
      MINIO_ACCESS_KEY: minioadmin
      MINIO_SECRET_KEY: "{{.MinioSecretKey}}"
      MINIO_BUCKET_UPLOADS: tetrix-uploads
      MINIO_REGION: us-east-1
      NODE_ENV: production
      SERVICE_NAME: worker
      LOG_LEVEL: "{{.LogLevel}}"
    volumes:
      - repo-storage:/app/repos
    restart: unless-stopped
    networks:
      - tetrix-network

  multi-agent:
    image: {{.DockerHubOrg}}/tetrix-multiagent:{{.TetrixVersion}}
    container_name: tetrix-multi-agent
    ports:
      - "{{.MultiAgentPort}}:7777"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      OPENAI_API_KEY: "{{.OpenAIAPIKey}}"
      JWT_SECRET_KEY: "{{.AuthSecret}}"
      DATABASE_URL: "postgresql://tetrix:{{.PostgresPassword}}@postgres:5432/tetrix"
      REDIS_URL: redis://redis:6379
      NEO4J_URI: bolt://neo4j:7687
      NEO4J_USERNAME: neo4j
      NEO4J_PASSWORD: dummy
      MEILISEARCH_URL: http://meilisearch:7700
      MEILISEARCH_KEY: "{{.MeilisearchKey}}"
      DEBUG: "false"
      WORKERS: "4"
      UVICORN_HOST: 0.0.0.0
      UVICORN_PORT: "7777"
      UVICORN_LOG_LEVEL: "{{.LogLevel}}"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:7777/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped
    networks:
      - tetrix-network

  openai-proxy:
    image: {{.DockerHubOrg}}/tetrix-openaiproxy:{{.TetrixVersion}}
    container_name: tetrix-openai-proxy
    ports:
      - "{{.OpenAIProxyPort}}:8085"
    depends_on:
      multi-agent:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      OPENAI_GATEWAY_PORT: "8085"
      NODE_ENV: production
      SERVICE_NAME: openai-proxy
      AGENTOS_BASE_URL: http://multi-agent:7777
      OPENAI_REDIS_HOST: redis
      OPENAI_REDIS_PORT: "6379"
      JWT_SECRET_KEY: "{{.AuthSecret}}"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8085/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    restart: unless-stopped
    networks:
      - tetrix-network

  credential-service:
    image: {{.DockerHubOrg}}/tetrix-credential-service:{{.TetrixVersion}}
    container_name: tetrix-credential-service
    depends_on:
      vault:
        condition: service_healthy
      mongodb:
        condition: service_healthy
    environment:
      NODE_ENV: production
      MONGODB_URI: mongodb://mongodb:27017/tetrix
      VAULT_ENDPOINT: http://vault:8200
      VAULT_TOKEN: "{{.VaultToken}}"
      SECRET_PROVIDER: vault
      PORT: "3001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped
    networks:
      - tetrix-network

# =============================================================================
# Volumes
# =============================================================================
volumes:
  postgres-data:
  neo4j-data:
  neo4j-logs:
  redis-data:
  meilisearch-data:
  minio-data:
  mongodb-data:
  repo-storage:

# =============================================================================
# Networks
# =============================================================================
networks:
  tetrix-network:
    driver: bridge
